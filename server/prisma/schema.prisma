generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  id                String        @id @default(cuid())
  name              String
  fullName          String
  entityType        EntityType    @default(INDIVIDUAL)
  pib               String?
  mbr               String?
  account           String?
  bank              String?
  phone             String?
  email             String        @unique
  bio               String?
  tgId              String?
  passwordHash      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  cleanActions      CleanAction[] @relation("PerformerRelation")
  supervisedActions CleanAction[] @relation("SupervisorRelation")
}

model Equipment {
  id           String        @id @default(cuid())
  numId        Int           @unique
  fullName     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cleanActions CleanAction[] @relation("EquipmentRelation")
}

model CleanAction {
  id           String       @id @default(cuid())
  equipmentId  String
  performerId  String
  cleaningType CleaningType @default(CURRENT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  supervisorId String
  equipmend    Equipment    @relation("EquipmentRelation", fields: [equipmentId], references: [id])
  performer    User         @relation("PerformerRelation", fields: [performerId], references: [id])
  supervisor   User         @relation("SupervisorRelation", fields: [supervisorId], references: [id])

  @@index([equipmentId], map: "CleanAction_equipmentId_fkey")
  @@index([performerId], map: "CleanAction_performerId_fkey")
  @@index([supervisorId], map: "CleanAction_supervisorId_fkey")
}

enum EntityType {
  INDIVIDUAL
  LEGAL_ENTITY
}

enum CleaningType {
  GENERAL
  CURRENT
  DISINFECTION
}

model Material {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  selfProduced          Boolean  @default(false)
  ingredients           Ingredient[]

  caloriesKcal          Decimal  @default(0) @db.Decimal(10, 3)
  fatGrams              Decimal  @default(0) @db.Decimal(10, 3)
  proteinGrams          Decimal  @default(0) @db.Decimal(10, 3)
  carbohydratesGrams    Decimal  @default(0) @db.Decimal(10, 3)
  sugarsGrams           Decimal  @default(0) @db.Decimal(10, 3)
  fiberGrams            Decimal  @default(0) @db.Decimal(10, 3)
  saltGrams             Decimal  @default(0) @db.Decimal(10, 3)
  VAT                   Float
  Price                 Float
  purchaseUnit          String
  purchaseUnitAmount    Float
  consumptionUnit       String
  ratio                 Float
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  batchPrefix        String   @unique
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            Batch[]
  processMaps        ProcessMap[]
  orderProducts      OrderProduct[]
  caloriesKcal       Decimal  @default(0) @db.Decimal(10, 3)
  fatGrams           Decimal  @default(0) @db.Decimal(10, 3)
  proteinGrams       Decimal  @default(0) @db.Decimal(10, 3)
  carbohydratesGrams Decimal  @default(0) @db.Decimal(10, 3)
  sugarsGrams        Decimal  @default(0) @db.Decimal(10, 3)
  fiberGrams         Decimal  @default(0) @db.Decimal(10, 3)
  saltGrams          Decimal  @default(0) @db.Decimal(10, 3)
  ingredients        Ingredient[]
}

model Batch {
  id        String   @id @default(cuid())
  productId String
  nettoWeight Float
  number    Int
  numberStr String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  storageDurationHours Int
  storageConditionId String
  storageCondition   StorageCondition @relation(fields: [storageConditionId], references: [id])
  processMapId String?
  processMap   ProcessMap? @relation(fields: [processMapId], references: [id])
  processDeviations String?
  samples Sample[]
  certificate Certificate?

  @@index([productId], map: "Batch_productId_fkey")
}

model ProcessMap {
  id        String   @id @default(cuid())
  name      String
  productId String
  outcome   Float
  rateOfLoss Float  @default(0.0)
  VAT       Float    @default(20.0)
  containerCost Float @default(35.0)
  dose      Float    @default(100.0)
  marginalCoefficient Float @default(2.01)
  outcomeUnit String  @default("g")
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   Batch[]
  parameters ProcessParameter[]
  ingredients Ingredient[]
}

model Ingredient {
  id           String      @id @default(cuid())
  productId    String?
  materialId   String?
  amount       Float
  product      Product?    @relation(fields: [productId], references: [id])
  material     Material?   @relation(fields: [materialId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  processMapId String
  processMap   ProcessMap  @relation(fields: [processMapId], references: [id])

  @@index([productId], map: "Ingredient_productId_fkey")
  @@index([materialId], map: "Ingredient_materialId_fkey")
  @@index([processMapId], map: "Ingredient_processMapId_fkey")
}

model ProcessParameter {
  id           String   @id @default(cuid())
  name         String
  value        String
  unit         String
  processMapId String
  processMap   ProcessMap @relation(fields: [processMapId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StorageCondition {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   Batch[]
}

model Order {
  id        String   @id @default(cuid())
  orderNumber String   @unique
  customerName String
  customerUserId String?
  orderDate   DateTime
  orderDateReady DateTime?
  products  OrderProduct[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderProduct {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Float
  dateReady   DateTime?
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId], map: "OrderProduct_orderId_fkey")
  @@index([productId], map: "OrderProduct_productId_fkey")
}

model Sample {
  id        String   @id @default(cuid())
  batchId   String
  number    Int
  numberStr String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch @relation(fields: [batchId], references: [id])
  studyAt DateTime?
  result String?
  note String?

  @@index([batchId], map: "Sample_batchId_fkey")
}

model CostSettings {
  id                         String   @id @default("singleton")
  marginalCoefficient        Float    @default(1.0)
  containerCost              Float    @default(0.0)
  productVat                 Float    @default(20.0)
  productWeight              Float    @default(100.0)
  productContainerCosts      Json     @default("{}")
  productMarginalCoefficients Json     @default("{}")
  productWeights             Json     @default("{}")
  productVats                Json     @default("{}")
  productMainProcessMaps     Json     @default("{}")
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Certificate {
  id        String   @id @default(cuid())
  numberYear Int
  number    Int
  numberStr String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch @relation(fields: [batchId], references: [id])
  batchId   String @unique
  extraCertificateData String @db.Text

  @@unique([numberYear, number], map: "Certificate_numberYear_number_key")
}