// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  fullName     String
  entityType   String   @default("INDIVIDUAL")
  pib          String?
  mbr          String?
  account      String?
  bank         String?
  phone        String?
  email        String   @unique
  bio          String?
  tgId         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cleanActions CleanAction[]
}

model Equipment {
  id           String   @id @default(cuid())
  numId        Int      @unique
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cleanActions CleanAction[]
}

model CleanAction {
  id           String   @id @default(cuid())
  equipmend    Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId  String
  performer    User @relation(fields: [performerId], references: [id])
  performerId  String
  cleaningType String 
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}