// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}
datasource db {
  provider = "mysql"
}

enum EntityType {
  INDIVIDUAL
  LEGAL_ENTITY
}

model User {
  id           String   @id @default(cuid())
  name         String
  fullName     String
  entityType   EntityType @default(INDIVIDUAL)
  pib          String?
  mbr          String?
  account      String?
  bank         String?
  phone        String?
  email        String   @unique
  bio          String?
  tgId         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cleanActions CleanAction[] @relation(name: "PerformerRelation")
  supervisedActions CleanAction[] @relation(name: "SupervisorRelation")
}

model Equipment {
  id           String   @id @default(cuid())
  numId        Int      @unique
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cleanActions CleanAction[] @relation(name: "EquipmentRelation")
}

enum CleaningType {
  GENERAL
  CURRENT
  DISINFECTION
}

model CleanAction {
  id           String   @id @default(cuid())
  equipmend    Equipment @relation(name: "EquipmentRelation", fields: [equipmentId], references: [id])
  equipmentId  String
  performer    User @relation(name: "PerformerRelation", fields: [performerId], references: [id])
  performerId  String
  supervisor   User @relation(name: "SupervisorRelation", fields: [supervisorId], references: [id])
  supervisorId String
  cleaningType CleaningType @default(CURRENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}