PORT=5000
DATABASE_URL=mysql://user:your_password@localhost:3306/df
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_DURATION_MINUTES=15

# SMTP requisites for website emails
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@yourdomain.com
SMTP_PASS=replace_with_smtp_or_app_password
SMTP_FROM=admin@yourdomain.com

# Recipients for website forms
CONTACT_EMAIL_TO=sales@yourdomain.com
SMTP_TO_FEEDBACK=sales@yourdomain.com
SMTP_TO_FREE_ORDER=sales@yourdomain.com

# Certificate Word template (.dotx) path
# Absolute path or path relative to server working directory.
CERTIFICATE_TEMPLATE_PATH=templates/certificate.dotx
